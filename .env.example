# ── Backend (token helper) — used by server/index.js ──────────────────────────
# Your Paytm Money API credentials. The secret stays server-side only.
PAYTM_API_KEY=
PAYTM_API_SECRET=

# Where the React app runs (the backend redirects here after login).
FRONTEND_URL=http://localhost:5173
# Port for the token-helper backend. MUST match the Return URL in the Paytm
# Developer Portal (set it to http://localhost:3000).
PORT=3000

# ── Frontend (Vite) — only VITE_* vars are exposed to the browser ─────────────
# Base URL of the token-helper backend.
VITE_BACKEND_URL=http://localhost:3000
# Optional: pre-fill a token manually instead of using the login flow.
VITE_PAYTM_PUBLIC_ACCESS_TOKEN=
