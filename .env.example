# ── Backend (token helper) — used by server/index.js (local) AND api/* (Vercel) ──
# Your Paytm Money API credentials. The secret stays server-side only — NEVER expose it.
PAYTM_API_KEY=
PAYTM_API_SECRET=

# ── Turso database (token persistence) ─────────────────────────────────────────
# Tokens are stored here, shared between local dev and the deployed site.
TURSO_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=

# Where the React app runs locally (the backend redirects here after a local login).
FRONTEND_URL=http://localhost:5173
# Port for the local token-helper backend.
PORT=5174

# ── Frontend (Vite) — only VITE_* vars are exposed to the browser ─────────────
# Local backend base URL. LEAVE THIS UNSET ON VERCEL: in production the API is
# same-origin under /api/*, so an empty/undefined value resolves to the same domain.
VITE_BACKEND_URL=http://localhost:5174
# Optional: pre-fill a token manually instead of using the login flow.
VITE_PAYTM_PUBLIC_ACCESS_TOKEN=

# ── Deploying to Vercel ────────────────────────────────────────────────────────
# Set these in the Vercel project's Environment Variables (NOT VITE_BACKEND_URL):
#   PAYTM_API_KEY, PAYTM_API_SECRET, TURSO_URL, TURSO_AUTH_TOKEN
# In the Paytm Developer Portal set the Return URL to your deployed root, e.g.
#   https://stocker-beige.vercel.app/
